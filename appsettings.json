{
  "ConnectionStrings": {
    "LivePlotDB": "Server={DB_SERVER},{DB_PORT};Database={DB_NAME};User Id={DB_USER};Password={DB_PASSWORD};TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Secret": "YourSuperSecretKeyForJwtTokenGeneration12345!",
    "Issuer": "LivePlotApi",
    "Audience": "LivePlotApi",
    "ExpirationInMinutes": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
